{
    "extends": "@tsconfig/node24/tsconfig.json",
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "es2015",
        "rootDir": "./src",
        "types": ["node"],
        "resolveJsonModule": true,
        "outDir": "./dist"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "bin/template/**", "test/**"]
}
